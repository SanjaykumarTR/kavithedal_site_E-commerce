# ─────────────────────────────────────────────────────────────────────────────
# Kavithedal Publications — Frontend Environment Variables
# Copy this file to .env and fill in your real values.
# All Vite env vars MUST start with VITE_ to be exposed to the browser.
# NEVER put secret keys here — frontend env vars are visible to all users.
# ─────────────────────────────────────────────────────────────────────────────

# The full URL of your Django backend API (no trailing slash)
# Local development:
VITE_API_URL=http://localhost:8000
# Production (replace with your actual Render backend URL):
# VITE_API_URL=https://kavithedal-api.onrender.com

# Razorpay publishable key (safe to expose — it is public by design)
# Get from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
